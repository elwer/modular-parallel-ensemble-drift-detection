# EWDD Configuration - Optimized by Optuna
#
# Two-level decision criteria for drift detection:
#
# Level 1 - Detector decision (per detector, across decision window):
#   How to decide if a single detector reports drift based on its results in the window
#   - "any": Detector reports drift if ANY sample in window triggered drift
#   - "all": Detector reports drift only if ALL samples in window triggered drift
#   - "majority": Detector reports drift if majority (>=50%) of samples triggered drift
detector_decision_criteria: any

# Level 2 - Ensemble decision (across detectors):
#   How to combine individual detector decisions into final ensemble decision
#   - "any": Ensemble reports drift if ANY detector reports drift
#   - "all": Ensemble reports drift only if ALL detectors report drift
#   - "majority": Ensemble reports drift if majority (>=50%) of detectors report drift
ensemble_decision_criteria: any

# Enable/disable verbose logging of shared memory operations
verbose: false

# Decision window size: number of recent samples to consider for drift decision
# The decision criteria is applied over this sliding window
decision_window: 50

# Suppression window: number of samples to suppress after drift detection
# This prevents consecutive retrainings that are too close together
# If not set, uses decision_window value
suppression_window: 0

detectors:
  - class: detectors.csddm.CSDDM
    params:
      n_samples: 56
      feature_proportion: 0.149770
      n_clusters: 8
      confidence: 0.025
  - class: detectors.d3.D3
    params:
      n_reference_samples: 228
      recent_samples_proportion: 0.306729
      threshold: 0.369093
  - class: detectors.ibdd.IBDD
    params:
      n_samples: 1139
      n_consecutive_deviations: 2
      n_permutations: 345
      update_interval: 71
