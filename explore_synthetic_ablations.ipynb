 "cells": [
  {
   "metadata": {},
   "cell_type": "raw",
   "outputs": [],
   "execution_count": null,
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Synthetic-Stream Ablation Explorer\\n\",\n",
    "    \"\\n\",\n",
    "    \"Explores the ablation study produced by `submit_synthetic.sh` / `run_synthetic.sbatch`.\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Ablation parameters** (encoded in the log file names `seed{S}_det-{C}_ens-{C}_dw{N}_sw{N}.log`):\\n\",\n",
    "    \"\\n\",\n",
    "    \"- `detector_criterion` (level 1): any | all | majority\\n\",\n",
    "    \"- `ensemble_criterion` (level 2): any | all | majority\\n\",\n",
    "    \"- `decision_window`: level-1 sliding window length\\n\",\n",
    "    \"- `suppression_window`: detection collapse window\\n\",\n",
    "    \"- `ensemble_size` (N): parsed from the `ENSEMBLE_N=...` lines inside each log\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Target metrics** (ensemble level only): `TP`, `FP`, `FN`, `delay`.\\n\",\n",
    "    \"\\n\",\n",
    "    \"> Note: there are no *true negatives* in this evaluation \\u2014 every sample without a drift\\n\",\n",
    "    \"> would be a TN, so the metric is meaningless for drift detection; the standard set is\\n\",\n",
    "    \"> TP / FP / FN (+ detection delay).\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import math\\n\",\n",
    "    \"import re\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import plotly.express as px\\n\",\n",
    "    \"import plotly.graph_objects as go\\n\",\n",
    "    \"\\n\",\n",
    "    \"RESULTS_DIR = Path(\\\"synthetic_results\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"FILENAME_RE = re.compile(\\n\",\n",
    "    \"    r\\\"seed(?P<seed>\\\\d+)\\\"\\n\",\n",
    "    \"    r\\\"_det-(?P<detector_criterion>any|all|majority)\\\"\\n\",\n",
    "    \"    r\\\"_ens-(?P<ensemble_criterion>any|all|majority)\\\"\\n\",\n",
    "    \"    r\\\"_dw(?P<decision_window>\\\\d+)\\\"\\n\",\n",
    "    \"    r\\\"_sw(?P<suppression_window>\\\\d+)\\\\.log$\\\"\\n\",\n",
    "    \")\\n\",\n",
    "    \"ENSEMBLE_RE = re.compile(\\n\",\n",
    "    \"    r\\\"^ENSEMBLE_N=(?P<N>\\\\d+): \\\"\\n\",\n",
    "    \"    r\\\"TP=(?P<TP>\\\\d+) FP=(?P<FP>\\\\d+) FN=(?P<FN>\\\\d+) \\\"\\n\",\n",
    "    \"    r\\\"DELAY=(?P<delay>[\\\\d.]+|nan)\\\",\\n\",\n",
    "    \"    re.MULTILINE,\\n\",\n",
    "    \")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Load all ablation logs into a single DataFrame\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"def load_results(results_dir: Path) -> pd.DataFrame:\\n\",\n",
    "    \"    rows = []\\n\",\n",
    "    \"    for log_path in sorted(results_dir.glob(\\\"*/*.log\\\")):\\n\",\n",
    "    \"        m = FILENAME_RE.search(log_path.name)\\n\",\n",
    "    \"        if m is None:\\n\",\n",
    "    \"            print(f\\\"[skip] unparsable file name: {log_path}\\\")\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"        params = m.groupdict()\\n\",\n",
    "    \"        text = log_path.read_text(errors=\\\"replace\\\")\\n\",\n",
    "    \"        for em in ENSEMBLE_RE.finditer(text):\\n\",\n",
    "    \"            rows.append({\\n\",\n",
    "    \"                \\\"dataset\\\": log_path.parent.name,\\n\",\n",
    "    \"                \\\"seed\\\": int(params[\\\"seed\\\"]),\\n\",\n",
    "    \"                \\\"detector_criterion\\\": params[\\\"detector_criterion\\\"],\\n\",\n",
    "    \"                \\\"ensemble_criterion\\\": params[\\\"ensemble_criterion\\\"],\\n\",\n",
    "    \"                \\\"decision_window\\\": int(params[\\\"decision_window\\\"]),\\n\",\n",
    "    \"                \\\"suppression_window\\\": int(params[\\\"suppression_window\\\"]),\\n\",\n",
    "    \"                \\\"N\\\": int(em[\\\"N\\\"]),\\n\",\n",
    "    \"                \\\"TP\\\": int(em[\\\"TP\\\"]),\\n\",\n",
    "    \"                \\\"FP\\\": int(em[\\\"FP\\\"]),\\n\",\n",
    "    \"                \\\"FN\\\": int(em[\\\"FN\\\"]),\\n\",\n",
    "    \"                \\\"delay\\\": float(em[\\\"delay\\\"]),\\n\",\n",
    "    \"            })\\n\",\n",
    "    \"    return pd.DataFrame(rows)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"df = load_results(RESULTS_DIR)\\n\",\n",
    "    \"print(f\\\"{len(df)} ensemble-level result rows loaded\\\")\\n\",\n",
    "    \"df.head()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Sanity check: grid coverage\\n\",\n",
    "    \"\\n\",\n",
    "    \"Each cell should show the same number of runs; missing combinations indicate failed/pending jobs.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"if not df.empty:\\n\",\n",
    "    \"    coverage = df.pivot_table(\\n\",\n",
    "    \"        index=[\\\"dataset\\\", \\\"detector_criterion\\\", \\\"ensemble_criterion\\\"],\\n\",\n",
    "    \"        columns=[\\\"decision_window\\\", \\\"suppression_window\\\"],\\n\",\n",
    "    \"        values=\\\"TP\\\",\\n\",\n",
    "    \"        aggfunc=\\\"count\\\",\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    display(coverage)\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print(\\\"No results found - check RESULTS_DIR.\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Aggregate across seeds\\n\",\n",
    "    \"\\n\",\n",
    "    \"Mean over seeds per ablation point. `delay` is averaged over the seeds where it is defined\\n\",\n",
    "    \"(NaN = no true positives at all for that run).\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"PARAM_COLS = [\\n\",\n",
    "    \"    \\\"dataset\\\", \\\"detector_criterion\\\", \\\"ensemble_criterion\\\",\\n\",\n",
    "    \"    \\\"decision_window\\\", \\\"suppression_window\\\", \\\"N\\\",\\n\",\n",
    "    \"]\\n\",\n",
    "    \"METRIC_COLS = [\\\"TP\\\", \\\"FP\\\", \\\"FN\\\", \\\"delay\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"agg = (\\n\",\n",
    "    \"    df.groupby(PARAM_COLS, as_index=False)[METRIC_COLS]\\n\",\n",
    "    \"      .mean()  # NaN delays are ignored per group unless all are NaN\\n\",\n",
    "    \")\\n\",\n",
    "    \"agg.head()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Interactive parallel-coordinates plot\\n\",\n",
    "    \"\\n\",\n",
    "    \"Each line is one ablation point (optionally seed-averaged). Drag along an axis to select a\\n\",\n",
    "    \"value range and highlight the matching configurations; drag axis names to reorder.\\n\",\n",
    "    \"\\n\",\n",
    "    \"The categorical criteria are mapped to integers (`any=0, all=1, majority=2`) so that they can\\n\",\n",
    "    \"be displayed on numeric parallel-coordinate axes.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"CRIT_ORDER = [\\\"any\\\", \\\"all\\\", \\\"majority\\\"]\\n\",\n",
    "    \"CRIT_TO_INT = {c: i for i, c in enumerate(CRIT_ORDER)}\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def parallel_plot(data: pd.DataFrame, color: str = \\\"FP\\\", title: str = \\\"\\\") -> go.Figure:\\n\",\n",
    "    \"    \\\"\\\"\\\"Parallel-coordinates plot of ablation parameters vs ensemble metrics.\\n\",\n",
    "    \"\\n\",\n",
    "    \"    NaN delays (runs without any TP) are shown at a sentinel value above the\\n\",\n",
    "    \"    maximum observed delay so the lines remain visible.\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    d = data.copy()\\n\",\n",
    "    \"    d[\\\"det_crit_i\\\"] = d[\\\"detector_criterion\\\"].map(CRIT_TO_INT)\\n\",\n",
    "    \"    d[\\\"ens_crit_i\\\"] = d[\\\"ensemble_criterion\\\"].map(CRIT_TO_INT)\\n\",\n",
    "    \"    delay_max = d[\\\"delay\\\"].max()\\n\",\n",
    "    \"    sentinel = (delay_max * 1.2) if not math.isnan(delay_max) else 1.0\\n\",\n",
    "    \"    d[\\\"delay_plot\\\"] = d[\\\"delay\\\"].fillna(sentinel)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    dims = [\\n\",\n",
    "    \"        dict(label=\\\"Detector criterion (lvl 1)\\\", values=d[\\\"det_crit_i\\\"],\\n\",\n",
    "    \"             tickvals=list(range(len(CRIT_ORDER))), ticktext=CRIT_ORDER),\\n\",\n",
    "    \"        dict(label=\\\"Ensemble criterion (lvl 2)\\\", values=d[\\\"ens_crit_i\\\"],\\n\",\n",
    "    \"             tickvals=list(range(len(CRIT_ORDER))), ticktext=CRIT_ORDER),\\n\",\n",
    "    \"        dict(label=\\\"Decision window\\\", values=d[\\\"decision_window\\\"]),\\n\",\n",
    "    \"        dict(label=\\\"Suppression window\\\", values=d[\\\"suppression_window\\\"]),\\n\",\n",
    "    \"        dict(label=\\\"Ensemble size N\\\", values=d[\\\"N\\\"]),\\n\",\n",
    "    \"        dict(label=\\\"TP\\\", values=d[\\\"TP\\\"]),\\n\",\n",
    "    \"        dict(label=\\\"FP\\\", values=d[\\\"FP\\\"]),\\n\",\n",
    "    \"        dict(label=\\\"FN\\\", values=d[\\\"FN\\\"]),\\n\",\n",
    "    \"        dict(label=\\\"Delay (NaN at top)\\\", values=d[\\\"delay_plot\\\"]),\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"    fig = go.Figure(go.Parcoords(\\n\",\n",
    "    \"        line=dict(color=d[color], colorscale=\\\"Turbo\\\", showscale=True,\\n\",\n",
    "    \"                  colorbar=dict(title=color)),\\n\",\n",
    "    \"        dimensions=dims,\\n\",\n",
    "    \"    ))\\n\",\n",
    "    \"    fig.update_layout(title=title, height=550, margin=dict(l=80, r=80, t=80))\\n\",\n",
    "    \"    return fig\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# One plot per dataset, seed-averaged. Change `color=` to \\\"TP\\\", \\\"FN\\\", \\\"delay\\\", ...\\n\",\n",
    "    \"for dataset in agg[\\\"dataset\\\"].unique():\\n\",\n",
    "    \"    fig = parallel_plot(\\n\",\n",
    "    \"        agg[agg[\\\"dataset\\\"] == dataset],\\n\",\n",
    "    \"        color=\\\"FP\\\",\\n\",\n",
    "    \"        title=f\\\"{dataset}: ablation parameters vs ensemble metrics (mean over seeds)\\\",\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    fig.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Drill-down: fix the ensemble size\\n\",\n",
    "    \"\\n\",\n",
    "    \"With `N` fixed, the remaining axes show the pure heuristic/window effects.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"N_FIXED = 16  # <- change me\\n\",\n",
    "    \"\\n\",\n",
    "    \"for dataset in agg[\\\"dataset\\\"].unique():\\n\",\n",
    "    \"    sel = agg[(agg[\\\"dataset\\\"] == dataset) & (agg[\\\"N\\\"] == N_FIXED)]\\n\",\n",
    "    \"    if sel.empty:\\n\",\n",
    "    \"        continue\\n\",\n",
    "    \"    fig = parallel_plot(\\n\",\n",
    "    \"        sel, color=\\\"TP\\\",\\n\",\n",
    "    \"        title=f\\\"{dataset}, N={N_FIXED}: heuristic / window ablation\\\",\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    fig.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Per-parameter marginal effects\\n\",\n",
    "    \"\\n\",\n",
    "    \"Quick non-interactive summaries: how each single parameter shifts the metrics, averaged over\\n\",\n",
    "    \"everything else.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"for param in [\\\"detector_criterion\\\", \\\"ensemble_criterion\\\",\\n\",\n",
    "    \"              \\\"decision_window\\\", \\\"suppression_window\\\", \\\"N\\\"]:\\n\",\n",
    "    \"    print(f\\\"\\\\n=== Marginal effect of {param} ===\\\")\\n\",\n",
    "    \"    display(df.groupby(param)[METRIC_COLS].mean().round(2))\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Criteria-combination heatmap (TP and FP side by side), per dataset.\\n\",\n",
    "    \"for dataset in df[\\\"dataset\\\"].unique():\\n\",\n",
    "    \"    sub = df[df[\\\"dataset\\\"] == dataset]\\n\",\n",
    "    \"    pivot = sub.pivot_table(index=\\\"detector_criterion\\\", columns=\\\"ensemble_criterion\\\",\\n\",\n",
    "    \"                            values=[\\\"TP\\\", \\\"FP\\\"], aggfunc=\\\"mean\\\")\\n\",\n",
    "    \"    fig = px.imshow(pivot[\\\"TP\\\"], text_auto=\\\".1f\\\", color_continuous_scale=\\\"Greens\\\",\\n\",\n",
    "    \"                    title=f\\\"{dataset}: mean TP by criteria combination\\\")\\n\",\n",
    "    \"    fig.update_layout(height=380, width=480)\\n\",\n",
    "    \"    fig.show()\\n\",\n",
    "    \"    fig = px.imshow(pivot[\\\"FP\\\"], text_auto=\\\".1f\\\", color_continuous_scale=\\\"Reds\\\",\\n\",\n",
    "    \"                    title=f\\\"{dataset}: mean FP by criteria combination\\\")\\n\",\n",
    "    \"    fig.update_layout(height=380, width=480)\\n\",\n",
    "    \"    fig.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Window-size interaction\\n\",\n",
    "    \"\\n\",\n",
    "    \"Decision window vs suppression window for a chosen metric and criteria combination.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"METRIC = \\\"FP\\\"            # <- change me: TP | FP | FN | delay\\n\",\n",
    "    \"DET_CRIT = \\\"majority\\\"    # <- change me\\n\",\n",
    "    \"ENS_CRIT = \\\"majority\\\"    # <- change me\\n\",\n",
    "    \"\\n\",\n",
    "    \"for dataset in df[\\\"dataset\\\"].unique():\\n\",\n",
    "    \"    sub = df[(df[\\\"dataset\\\"] == dataset)\\n\",\n",
    "    \"             & (df[\\\"detector_criterion\\\"] == DET_CRIT)\\n\",\n",
    "    \"             & (df[\\\"ensemble_criterion\\\"] == ENS_CRIT)]\\n\",\n",
    "    \"    if sub.empty:\\n\",\n",
    "    \"        continue\\n\",\n",
    "    \"    pivot = sub.pivot_table(index=\\\"decision_window\\\", columns=\\\"suppression_window\\\",\\n\",\n",
    "    \"                            values=METRIC, aggfunc=\\\"mean\\\")\\n\",\n",
    "    \"    fig = px.imshow(pivot, text_auto=\\\".1f\\\", color_continuous_scale=\\\"Viridis\\\",\\n\",\n",
    "    \"                    labels=dict(x=\\\"suppression_window\\\", y=\\\"decision_window\\\", color=METRIC),\\n\",\n",
    "    \"                    title=f\\\"{dataset} ({DET_CRIT}/{ENS_CRIT}): mean {METRIC}\\\")\\n\",\n",
    "    \"    fig.update_layout(height=420, width=520)\\n\",\n",
    "    \"    fig.show()\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
    " \"metadata\": {\n",
    "  \"kernelspec\": {\n",
    "   \"display_name\": \"Python 3\",\n",
    "   \"language\": \"python\",\n",
    "   \"name\": \"python3\"\n",
    "  },\n",
    "  \"language_info\": {\n",
    "   \"name\": \"python\",\n",
    "   \"version\": \"3\"\n",
    "  }\n",
    " },\n",
